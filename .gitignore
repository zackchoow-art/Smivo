# ════════════════════════════════════════════════════════
# Smivo Monorepo — Root .gitignore
# ════════════════════════════════════════════════════════

# ─── Flutter (app/) ────────────────────────────────────
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/.pub-cache/
app/.pub/
app/build/
app/.fvm/
app/pubspec.lock

# ─── React Admin (admin/) ─────────────────────────────
admin/node_modules/
admin/dist/
admin/.env
admin/.env.local
admin/.env.*.local

# ─── IDE ───────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ─── Secrets ───────────────────────────────────────────
.env
.env.local
.env.*.local
app/.env
app/.env.local

# ─── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── iOS (app/ios/) ────────────────────────────────────
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec

# ─── Android (app/android/) ────────────────────────────
app/android/.gradle/
app/android/captures/
app/android/local.properties
app/android/**/GeneratedPluginRegistrant.java

# ─── Root-level remnants (pre-monorepo) ────────────────
.dart_tool/
ios/

# ─── Misc ──────────────────────────────────────────────
.env.db
db.sh
