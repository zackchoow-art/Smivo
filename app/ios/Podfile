# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# NOTE: Force all pods to generate modulemap files.
# Required because TOCropViewController 3.1.2 doesn't define a module,
# causing "Module not found" in image_cropper on Xcode 26.
use_frameworks!

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # NOTE: Force module definition so @import works for all pods.
      # TOCropViewController 3.1.2 doesn't set this, causing
      # "Module not found" when image_cropper tries @import.
      config.build_settings['DEFINES_MODULE'] = 'YES'

      # NOTE: Align all pods to the project minimum deployment target.
      # Prevents "deployment target lower than minimum" warnings.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'

      # NOTE: Suppress "requires a development team" errors for all pod targets.
      # Pod frameworks do not need independent signing — only the main Runner
      # target requires a team. Setting this avoids Xcode prompting for a team
      # on every Flutter plugin sub-target.
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'

      # NOTE: Force dSYM generation for Release/Profile configs on all pod targets.
      # Without this, objective_c.framework (and other FFI frameworks) only emit
      # inline DWARF — no standalone .dSYM file is produced, causing App Store
      # Connect to reject the archive with "did not include a dSYM" UUID errors.
      # Debug config is excluded because dSYM is not needed for local development.
      if config.name != 'Debug'
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      end

      # NOTE: Bitcode is deprecated and can cause build failures in modern Xcode.
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
