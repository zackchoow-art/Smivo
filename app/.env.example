# Smivo App Environment Variables Template
# Copy this file to .env and fill in the actual values.
# DO NOT commit the .env file to version control.

# --- SUPABASE CONFIGURATION ---
# [REQUIRED] The API URL of your Supabase project.
# Found in: Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# [REQUIRED] The anonymous API key for your Supabase project.
# Found in: Supabase Dashboard -> Settings -> API -> Project API keys (anon / public)
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- PUSH NOTIFICATIONS ---
# [OPTIONAL / PHASE 2] The App ID for OneSignal push notifications.
# Found in: OneSignal Dashboard -> Settings -> Keys & IDs
ONESIGNAL_APP_ID=your-onesignal-app-id
